{
  "compileOnSave": false,
  "compilerOptions": {
    "alwaysStrict": true,
    "declaration": false,
    "lib": ["dom", "es2020"],
    "module": "none",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "outDir": "dist",
    "removeComments": true,
    "sourceMap": false,
    "strictFunctionTypes": true,
    "strictNullChecks": false,
    "target": "es2020"
  },
  "include": ["src/**/*.ts"]
}
